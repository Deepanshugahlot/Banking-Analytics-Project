    <worksheet name='Risk Category by Occupation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Risk Distribution Across Occupations</run>
          </formatted-text>
        </title>
      </layout-options>
      <repository-location derived-from='https://public.tableau.com/workbooks/BankingProject_17829830247920/RiskCategorybyOccupation?rev=' id='131576593' path='/workbooks/BankingProject_17829830247920' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='fact_transactions+' name='federated.1sb2ti50ooglt8107qa5z18x3lfr' />
          </datasources>
          <datasource-dependencies datasource='federated.1sb2ti50ooglt8107qa5z18x3lfr'>
            <column caption='Age Group' datatype='string' name='[Calculation_1958522702905345]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age] &gt;= 15 AND [age] &lt; 20 THEN &quot;15-19&quot;&#13;&#10;ELSEIF [age] &gt;= 20 AND [age] &lt; 25 THEN &quot;20-24&quot;&#13;&#10;ELSEIF [age] &gt;= 25 AND [age] &lt; 30 THEN &quot;25-29&quot;&#13;&#10;ELSEIF [age] &gt;= 30 AND [age] &lt; 35 THEN &quot;30-34&quot;&#13;&#10;ELSEIF [age] &gt;= 35 AND [age] &lt; 40 THEN &quot;35-39&quot;&#13;&#10;ELSEIF [age] &gt;= 40 AND [age] &lt; 45 THEN &quot;40-44&quot;&#13;&#10;ELSEIF [age] &gt;= 45 AND [age] &lt; 50 THEN &quot;45-49&quot;&#13;&#10;ELSEIF [age] &gt;= 50 AND [age] &lt; 55 THEN &quot;50-54&quot;&#13;&#10;ELSEIF [age] &gt;= 55 AND [age] &lt; 60 THEN &quot;55-59&quot;&#13;&#10;ELSEIF [age] &gt;= 60 AND [age] &lt; 65 THEN &quot;60-64&quot;&#13;&#10;ELSEIF [age] &gt;= 65 AND [age] &lt; 70 THEN &quot;65-69&quot;&#13;&#10;ELSE &quot;70+&quot;&#13;&#10;END' />
            </column>
            <column caption='Account Id' datatype='string' name='[account_id]' role='dimension' type='nominal' />
            <column caption='Age' datatype='integer' name='[age]' role='measure' type='quantitative' />
            <column-instance column='[account_id]' derivation='Count' name='[cnt:account_id:qk]' pivot='key' type='quantitative' />
            <column-instance column='[customer_id (dim_customers.csv)]' derivation='CountD' name='[ctd:customer_id (dim_customers.csv):qk]' pivot='key' type='quantitative' />
            <column aggregation='CountD' caption='Customer Id (Dim Customers.Csv)' datatype='string' default-role='measure' default-type='quantitative' name='[customer_id (dim_customers.csv)]' role='dimension' type='nominal' />
            <column-instance column='[occupation]' derivation='None' name='[none:occupation:nk]' pivot='key' type='nominal' />
            <column-instance column='[risk_category]' derivation='None' name='[none:risk_category:nk]' pivot='key' type='nominal' />
            <column caption='Occupation' datatype='string' name='[occupation]' role='dimension' type='nominal' />
            <column-instance column='[customer_id (dim_customers.csv)]' derivation='CountD' name='[pcto:ctd:customer_id (dim_customers.csv):qk:3]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' type='PctTotal' />
            </column-instance>
            <column caption='Risk Category' datatype='string' name='[risk_category]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[Action (Age Group,Occupation)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action3_27BAB5B98012467A956163353BFEFD2F]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[Calculation_1958522702905345]' />
              <groupfilter function='level-members' level='[occupation]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:occupation:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Business Owner&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Retired&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Salaried - Government&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Salaried - Private&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Self-Employed&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Student&quot;' />
              <groupfilter function='member' level='[none:occupation:nk]' member='&quot;Unemployed&quot;' />
            </groupfilter>
          </filter>
          <computed-sort column='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:risk_category:nk]' direction='ASC' using='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[cnt:account_id:qk]' />
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:occupation:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[ctd:customer_id (dim_customers.csv):qk]' shelf='rows' />
          </shelf-sorts>
          <slices>
            <column>[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:occupation:nk]</column>
            <column>[federated.1sb2ti50ooglt8107qa5z18x3lfr].[Action (Age Group,Occupation)]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='title' class='0' field='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[ctd:customer_id (dim_customers.csv):qk]' scope='cols' value='Number of Customers' />
          </style-rule>
          <style-rule element='label'>
            <format attr='font-size' scope='rows' value='9' />
            <format attr='font-size' scope='cols' value='12' />
            <format attr='font-weight' scope='cols' value='bold' />
            <format attr='color' scope='cols' value='#000000' />
            <format attr='color' scope='rows' value='#000000' />
            <format attr='font-weight' scope='rows' value='bold' />
          </style-rule>
          <style-rule element='worksheet'>
            <format attr='display-field-labels' scope='rows' value='false' />
            <format attr='display-field-labels' scope='cols' value='false' />
          </style-rule>
          <style-rule element='gridline'>
            <format attr='line-visibility' scope='cols' value='off' />
            <format attr='stroke-size' value='0' />
          </style-rule>
          <style-rule element='zeroline'>
            <format attr='stroke-size' value='0' />
            <format attr='line-visibility' value='off' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <mark-sizing mark-sizing-setting='marks-scaling-off' />
            <encodings>
              <color column='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:risk_category:nk]' />
              <text column='[federated.1sb2ti50ooglt8107qa5z18x3lfr].[pcto:ctd:customer_id (dim_customers.csv):qk:3]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run bold='true'><![CDATA[Occupation:  <[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:occupation:nk]>]]></run>
                <run>Æ&#10;</run>
                <run bold='true'><![CDATA[Risk Category:  <[federated.1sb2ti50ooglt8107qa5z18x3lfr].[none:risk_category:nk]>]]></run>
                <run>Æ&#10;</run>
